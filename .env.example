DIR_ENVIRONMENT=local
DIR_LOG_LEVEL=INFO
DIR_CORS_ORIGINS=["http://localhost:5173"]

# Optional external services. The app works locally without these.
DIR_DATABASE_URL=postgresql+psycopg://resolver:resolver@postgres:5432/resolver
DIR_REDIS_URL=redis://redis:6379/0
DIR_RABBITMQ_URL=amqp://resolver:resolver@rabbitmq:5672/

# Optional LLM. Leave provider as local for deterministic no-credit demo mode.
DIR_LLM_PROVIDER=local

# Groq OpenAI-compatible mode.
DIR_GROQ_API_KEY=
DIR_GROQ_BASE_URL=https://api.groq.com/openai/v1
DIR_LLM_MODEL=llama-3.1-8b-instant

# OpenAI or another OpenAI-compatible endpoint.
DIR_OPENAI_API_KEY=
DIR_OPENAI_BASE_URL=
DIR_USE_MOCK_LLM=false
